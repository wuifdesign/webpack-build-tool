{
  "name": "webpack-build-tool",
  "version": "0.0.17",
  "description": "Commands for building JS/TS/CSS/SCSS files.",
  "author": "wuifdesign",
  "license": "MIT",
  "type": "module",
  "types": "global.d.ts",
  "repository": "https://github.com/wuifdesign/webpack-build-tool",
  "keywords": [
    "webpack",
    "typescript",
    "javascript",
    "sass",
    "css",
    "builder"
  ],
  "files": [
    "__mocks__",
    "build",
    "global.d.ts"
  ],
  "bin": {
    "webpack-build-tool": "./build/cli/webpack-build-tool.js"
  },
  "scripts": {
    "clean": "rimraf ./build",
    "build": "npm run clean && tsc --skipLibCheck",
    "watch": "npm run clean && tsc -w --skipLibCheck",
    "lint": "eslint ./src"
  },
  "dependencies": {
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@swc/core": "^1.3.84",
    "@swc/jest": "^0.2.29",
    "@types/jest": "^29.5.4",
    "autoprefixer": "^10.4.15",
    "babel-loader": "^9.1.3",
    "browserslist": "^4.21.10",
    "chalk": "^5.3.0",
    "core-js": "^3.32.2",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "dotenv": "^16.3.1",
    "eslint": "^8.49.0",
    "eslint-webpack-plugin": "^4.0.1",
    "filesize": "^10.0.12",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "gzip-size": "^7.0.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "log-update": "^5.0.1",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-loader": "^7.3.3",
    "pretty-ms": "^8.0.0",
    "sass": "^1.66.1",
    "sass-loader": "^13.3.2",
    "speed-measure-webpack-plugin": "^1.5.0",
    "strip-ansi": "^7.1.0",
    "style-loader": "^3.3.3",
    "swc-loader": "^0.2.3",
    "terser-webpack-plugin": "^5.3.9",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-bundle-analyzer": "^4.9.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-manifest-plugin": "^5.0.0",
    "webpack-remove-empty-scripts": "^1.0.4"
  },
  "devDependencies": {
    "@types/speed-measure-webpack-plugin": "^1.3.4",
    "@types/webpack-bundle-analyzer": "^4.6.0",
    "@types/webpack-dev-server": "^4.7.2",
    "eslint-config-wuif": "^0.0.8",
    "rimraf": "^5.0.1"
